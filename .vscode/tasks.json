{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PIME: init submodules",
      "type": "shell",
      "command": "git",
      "args": [
        "submodule",
        "update",
        "--init",
        "--recursive"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "PIME: build all via build.bat",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/d",
        "/c",
        "build.bat"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "PIME: configure Win32",
      "type": "shell",
      "command": "${workspaceFolder}\\.vscode\\run-cmake.cmd",
      "args": [
        "-S",
        ".",
        "-B",
        "build",
        "-G",
        "Visual Studio 17 2022",
        "-A",
        "Win32",
        "-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "PIME: build Win32 Release",
      "type": "shell",
      "command": "${workspaceFolder}\\.vscode\\run-cmake.cmd",
      "args": [
        "--build",
        "build",
        "--config",
        "Release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "PIME: configure x64",
      "type": "shell",
      "command": "${workspaceFolder}\\.vscode\\run-cmake.cmd",
      "args": [
        "-S",
        ".",
        "-B",
        "build64",
        "-G",
        "Visual Studio 17 2022",
        "-A",
        "x64",
        "-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "PIME: build x64 PIMETextService",
      "type": "shell",
      "command": "${workspaceFolder}\\.vscode\\run-cmake.cmd",
      "args": [
        "--build",
        "build64",
        "--config",
        "Release",
        "--target",
        "PIMETextService"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "PIME: configure ARM64",
      "type": "shell",
      "command": "${workspaceFolder}\\.vscode\\run-cmake.cmd",
      "args": [
        "-S",
        ".",
        "-B",
        "build_arm64",
        "-G",
        "Visual Studio 17 2022",
        "-A",
        "ARM64",
        "-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "PIME: build ARM64 PIMETextService",
      "type": "shell",
      "command": "${workspaceFolder}\\.vscode\\run-cmake.cmd",
      "args": [
        "--build",
        "build_arm64",
        "--config",
        "Release",
        "--target",
        "PIMETextService"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "PIME: build McBopomofo assets",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/d",
        "/c",
        "cd /d McBopomofoWeb && npm install && npm run build:pime"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "PIME: run Python backend",
      "type": "shell",
      "command": "py",
      "args": [
        "-3",
        "python\\server.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "PIME: run Node backend",
      "type": "shell",
      "command": "node",
      "args": [
        "node\\server.js"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "PIME: manual chewing test",
      "type": "shell",
      "command": "py",
      "args": [
        "-3",
        "tests\\chewing_test.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
